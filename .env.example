PORT=5000
# SCHEDULER_CRON=* * * * *
# SCHEDULER_TZ=America/Los_Angeles
# Minutes between outbound `sent` WhatsApp nudges per user (default 180)
# SCHEDULER_SEND_COOLDOWN_MINUTES=180

SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key
# scheduler_logs: add text column decision_type (sleep_based | fatigue_based | normal) if missing

TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# GET /test-whatsapp (quote E.164)
# TEST_WHATSAPP_TO="+919629071076"
# TEST_WHATSAPP_FALLBACK="+919629071076"

# TEST_WHATSAPP_MESSAGE=Hello from test route
# Twilio WhatsApp `from` (sandbox default below)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886


